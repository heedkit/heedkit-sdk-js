# Copy to .env.local and fill in. Vite only exposes vars prefixed with VITE_.

# Public project key from the FeatureKit console Install page (or db/seeds).
# Never commit a real key.
VITE_FEATUREKIT_PROJECT_KEY=pk_REPLACE_ME

# Rails endpoint (bare origin — the SDK appends /sdk itself).
# Browser dev default:
VITE_FEATUREKIT_API_URL=http://featurekit.localhost:3000
