{
  "name": "@featurekit/sdk-js",
  "version": "0.1.0",
  "description": "Feature Kit SDK \u2014 pure JavaScript. Zero dependencies. Works in any browser, script tag, or framework.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/featurekit.iife.js",
  "jsdelivr": "./dist/featurekit.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "feedback",
    "feature-request",
    "voting",
    "roadmap",
    "sdk",
    "vanilla-js"
  ]
}