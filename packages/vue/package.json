{
  "name": "@heedkit/sdk-vue",
  "version": "0.1.0",
  "private": true,
  "description": "HeedKit feedback widget \u2014 Vue bindings",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && vue-tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@heedkit/sdk-js": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4",
    "vue": "^3.5.12",
    "vue-tsc": "^2.1.10"
  }
}
