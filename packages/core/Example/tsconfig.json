{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"]
  },
  // We import the SDK straight from its TypeScript source (../src), so the
  // example's type-check needs to see files outside this folder.
  "include": ["main.ts", "vite-env.d.ts", "../src"]
}
